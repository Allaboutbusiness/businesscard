{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/card/조기열", "destination": "/card/jokiyeol.html" },
    { "source": "/card/유우선", "destination": "/card/yuwooseon.html" },
    { "source": "/card/류예주", "destination": "/card/ryuyeju.html" },
    { "source": "/card/이승원", "destination": "/card/leeseungwon.html" },
    { "source": "/card/안지수", "destination": "/card/anjisu.html" },
    { "source": "/card/채용현", "destination": "/card/chaeyonghyun.html" },
    { "source": "/card/송기훈", "destination": "/card/songgihoon.html" },
    { "source": "/card/김진기", "destination": "/card/jinki.html" },
    { "source": "/post/:id", "destination": "/api/render-post?id=:id" },
    { "source": "/notice", "destination": "/api/render-list?category=notice" },
    { "source": "/posts", "destination": "/api/render-list?category=post" },
    { "source": "/sitemap.xml", "destination": "/api/sitemap" }
  ],
  "redirects": [
    { "source": "/index-team-v2", "destination": "/", "permanent": true },
    { "source": "/index-team", "destination": "/", "permanent": true },
    { "source": "/team", "destination": "/", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Permissions-Policy", "value": "geolocation=(), microphone=(), camera=(), payment=()" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/(.*)\\.(jpg|jpeg|png|webp|mp4|ico|svg|woff2)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=604800" }]
    }
  ]
}
